<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApp.Pages.ProfilePage"
             Title="Profile"
             BackgroundColor="#F4F0FB">

    <Shell.BackgroundColor>#7B5EA7</Shell.BackgroundColor>
    <Shell.ForegroundColor>White</Shell.ForegroundColor>
    <Shell.TitleColor>White</Shell.TitleColor>

    <VerticalStackLayout Padding="36,60,36,36"
                         Spacing="0"
                         VerticalOptions="Start">

        <\!-- Avatar -->
        <Frame CornerRadius="50"
               WidthRequest="100"
               HeightRequest="100"
               Padding="0"
               HasShadow="True"
               HorizontalOptions="Center"
               BackgroundColor="#7B5EA7"
               IsClippedToBounds="True"
               Margin="0,0,0,20">
            <Label x:Name="AvatarLabel"
                   Text="U"
                   FontSize="44"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Frame>

        <\!-- Username -->
        <Label x:Name="UserNameLabel"
               Text="User"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="#1A1A2E"
               HorizontalOptions="Center"
               Margin="0,0,0,4" />

        <\!-- Email -->
        <Label x:Name="EmailLabel"
               Text="user@example.com"
               FontSize="14"
               TextColor="#6B6B8A"
               HorizontalOptions="Center"
               Margin="0,0,0,48" />

        <\!-- Stats Card -->
        <Frame BackgroundColor="White"
               CornerRadius="16"
               Padding="20,16"
               HasShadow="False"
               BorderColor="#EDE7F6"
               Margin="0,0,0,36">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                    <Label x:Name="PendingCountLabel"
                           Text="0"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#7B5EA7"
                           HorizontalOptions="Center" />
                    <Label Text="Pending"
                           FontSize="12"
                           TextColor="#6B6B8A"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
                <BoxView Grid.Column="0"
                         WidthRequest="1"
                         BackgroundColor="#EDE7F6"
                         HorizontalOptions="End"
                         VerticalOptions="Fill" />
                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                    <Label x:Name="CompletedCountLabel"
                           Text="0"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#5CB85C"
                           HorizontalOptions="Center" />
                    <Label Text="Completed"
                           FontSize="12"
                           TextColor="#6B6B8A"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <\!-- Sign Out Button -->
        <Button Text="SIGN OUT"
                BackgroundColor="#1A1A2E"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="15"
                CharacterSpacing="1.5"
                CornerRadius="12"
                HeightRequest="54"
                Clicked="OnSignOutClicked" />

    </VerticalStackLayout>
</ContentPage>
