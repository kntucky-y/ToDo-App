<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ToDoApp.ViewModels"
             xmlns:models="clr-namespace:ToDoApp"
             x:Class="ToDoApp.Pages.TodoPage"
             x:DataType="vm:AppViewModel"
             x:Name="Page"
             Title="ToDo"
             BackgroundColor="#F4F0FB">

    <Shell.BackgroundColor>#7B5EA7</Shell.BackgroundColor>
    <Shell.ForegroundColor>White</Shell.ForegroundColor>
    <Shell.TitleColor>White</Shell.TitleColor>

    <Grid RowDefinitions="*">

        <\!-- Empty State -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="12"
                             Padding="32"
                             IsVisible="{Binding IsPendingEmpty}">
            <Label Text="&#x1F4CB;"
                   FontSize="60"
                   HorizontalOptions="Center" />
            <Label Text="No tasks yet\!"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="#7B5EA7"
                   HorizontalOptions="Center" />
            <Label Text="Tap the + button to add your first task."
                   FontSize="13"
                   TextColor="#6B6B8A"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <\!-- Task ListView -->
        <ListView Grid.Row="0"
                  x:Name="TodoListView"
                  ItemsSource="{Binding PendingItems}"
                  BackgroundColor="Transparent"
                  SeparatorVisibility="None"
                  HasUnevenRows="True"
                  SelectionMode="None"
                  Margin="0,8,0,80"
                  IsVisible="{Binding IsPendingEmpty, Converter={StaticResource InvertBoolConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ToDoClass">
                    <ViewCell>
                        <Frame Margin="16,6,16,0"
                               Padding="0"
                               CornerRadius="14"
                               BackgroundColor="White"
                               HasShadow="False"
                               BorderColor="#EDE7F6">
                            <Grid Padding="16,14"
                                  ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <VerticalStackLayout Grid.Column="0"
                                                     VerticalOptions="Center"
                                                     Spacing="3">
                                    <Label Text="{Binding item_name}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#1A1A2E"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding item_description}"
                                           FontSize="12"
                                           TextColor="#6B6B8A"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        x:DataType="{x:Null}"
                                        Text="&#x1F5D1;"
                                        BackgroundColor="#FFF0F0"
                                        TextColor="#E84040"
                                        CornerRadius="10"
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        Padding="0"
                                        FontSize="18"
                                        Command="{Binding DeleteTodoCommand, Source={x:Static vm:AppViewModel.Instance}}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="2"
                                        x:DataType="{x:Null}"
                                        Text="&#x2713;"
                                        BackgroundColor="#F0FFF4"
                                        TextColor="#5CB85C"
                                        CornerRadius="10"
                                        WidthRequest="42"
                                        HeightRequest="42"
                                        Padding="0"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        Command="{Binding CompleteTodoCommand, Source={x:Static vm:AppViewModel.Instance}}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <\!-- Floating Add Button -->
        <Button Grid.Row="0"
                x:DataType="{x:Null}"
                Text="+"
                BackgroundColor="#7B5EA7"
                TextColor="White"
                FontSize="28"
                FontAttributes="Bold"
                CornerRadius="30"
                WidthRequest="60"
                HeightRequest="60"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,24,24"
                Command="{Binding AddCommand}"
                Shadow="{Shadow Brush='#44000000', Offset='0,4', Radius='8'}" />

    </Grid>
</ContentPage>
