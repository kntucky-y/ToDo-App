<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoApp.Pages.SignUpPage"
             BackgroundColor="#F4F0FB"
             Title="Create Account">

    <Shell.BackgroundColor>#7B5EA7</Shell.BackgroundColor>
    <Shell.ForegroundColor>White</Shell.ForegroundColor>
    <Shell.TitleColor>White</Shell.TitleColor>
    <NavigationPage.BackButtonTitle>Sign In</NavigationPage.BackButtonTitle>

    <ScrollView>
        <VerticalStackLayout Padding="36,40,36,36" Spacing="0">

            <\!-- Logo -->
            <Frame CornerRadius="24"
                   WidthRequest="80"
                   HeightRequest="80"
                   Padding="0"
                   HasShadow="True"
                   HorizontalOptions="Center"
                   BackgroundColor="#7B5EA7"
                   IsClippedToBounds="True"
                   Margin="0,0,0,16">
                <Label Text="&#x2713;"
                       FontSize="38"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontAttributes="Bold" />
            </Frame>

            <Label Text="Join TaskFlow"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#1A1A2E"
                   HorizontalOptions="Center"
                   Margin="0,0,0,4" />
            <Label Text="Create your free account"
                   FontSize="13"
                   TextColor="#6B6B8A"
                   HorizontalOptions="Center"
                   Margin="0,0,0,32" />

            <\!-- Username -->
            <Label Text="USERNAME"
                   FontSize="11" FontAttributes="Bold" TextColor="#7B5EA7"
                   CharacterSpacing="1.5" Margin="0,0,0,6" />
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16,4"
                   HasShadow="False" BorderColor="#D8CEEE" Margin="0,0,0,16">
                <Entry x:Name="UserNameEntry" Placeholder="Choose a username"
                       PlaceholderColor="#C0B8D8" TextColor="#1A1A2E"
                       BackgroundColor="Transparent" FontSize="15" />
            </Frame>

            <\!-- Email -->
            <Label Text="EMAIL ADDRESS"
                   FontSize="11" FontAttributes="Bold" TextColor="#7B5EA7"
                   CharacterSpacing="1.5" Margin="0,0,0,6" />
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16,4"
                   HasShadow="False" BorderColor="#D8CEEE" Margin="0,0,0,16">
                <Entry x:Name="EmailEntry" Placeholder="you@example.com"
                       PlaceholderColor="#C0B8D8" TextColor="#1A1A2E"
                       BackgroundColor="Transparent" FontSize="15" Keyboard="Email" />
            </Frame>

            <\!-- Password -->
            <Label Text="PASSWORD"
                   FontSize="11" FontAttributes="Bold" TextColor="#7B5EA7"
                   CharacterSpacing="1.5" Margin="0,0,0,6" />
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16,4"
                   HasShadow="False" BorderColor="#D8CEEE" Margin="0,0,0,16">
                <Entry x:Name="PasswordEntry" Placeholder="At least 6 characters"
                       PlaceholderColor="#C0B8D8" TextColor="#1A1A2E"
                       BackgroundColor="Transparent" FontSize="15" IsPassword="True" />
            </Frame>

            <\!-- Confirm Password -->
            <Label Text="CONFIRM PASSWORD"
                   FontSize="11" FontAttributes="Bold" TextColor="#7B5EA7"
                   CharacterSpacing="1.5" Margin="0,0,0,6" />
            <Frame BackgroundColor="White" CornerRadius="12" Padding="16,4"
                   HasShadow="False" BorderColor="#D8CEEE" Margin="0,0,0,32">
                <Entry x:Name="ConfirmEntry" Placeholder="Re-enter password"
                       PlaceholderColor="#C0B8D8" TextColor="#1A1A2E"
                       BackgroundColor="Transparent" FontSize="15" IsPassword="True" />
            </Frame>

            <\!-- Sign Up Button -->
            <Button Text="SIGN UP"
                    BackgroundColor="#7B5EA7" TextColor="White"
                    FontAttributes="Bold" FontSize="15" CharacterSpacing="1.5"
                    CornerRadius="12" HeightRequest="54"
                    Margin="0,0,0,14"
                    Clicked="OnSignUpClicked" />

            <\!-- Back to Sign In Button -->
            <Button Text="ALREADY HAVE AN ACCOUNT"
                    BackgroundColor="Transparent" TextColor="#7B5EA7"
                    FontAttributes="Bold" FontSize="13" CharacterSpacing="1"
                    CornerRadius="12" HeightRequest="50"
                    BorderColor="#7B5EA7" BorderWidth="1.5"
                    Clicked="OnBackToSignInClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
