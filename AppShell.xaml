<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:ToDoApp.Pages"
    Shell.NavBarHasShadow="True">

    <Shell.Resources>
        <ResourceDictionary>
            <Style TargetType="TabBar">
                <Setter Property="Shell.TabBarBackgroundColor" Value="#FFFFFF" />
                <Setter Property="Shell.TabBarForegroundColor" Value="#7B5EA7" />
                <Setter Property="Shell.TabBarTitleColor" Value="#7B5EA7" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="#B0A0D0" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar Shell.TabBarBackgroundColor="#FFFFFF"
            Shell.TabBarForegroundColor="#7B5EA7"
            Shell.TabBarTitleColor="#7B5EA7"
            Shell.TabBarUnselectedColor="#B0A0D0">

        <Tab Title="ToDo" Icon="tab_todo.png">
            <ShellContent Route="todopage"
                          Shell.BackgroundColor="#7B5EA7"
                          Shell.ForegroundColor="White"
                          Shell.TitleColor="White"
                          ContentTemplate="{DataTemplate pages:TodoPage}" />
        </Tab>

        <Tab Title="Completed" Icon="tab_done.png">
            <ShellContent Route="completedpage"
                          Shell.BackgroundColor="#7B5EA7"
                          Shell.ForegroundColor="White"
                          Shell.TitleColor="White"
                          ContentTemplate="{DataTemplate pages:CompletedPage}" />
        </Tab>

        <Tab Title="Profile" Icon="tab_profile.png">
            <ShellContent Route="profilepage"
                          Shell.BackgroundColor="#7B5EA7"
                          Shell.ForegroundColor="White"
                          Shell.TitleColor="White"
                          ContentTemplate="{DataTemplate pages:ProfilePage}" />
        </Tab>

    </TabBar>
</Shell>
